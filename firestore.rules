rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Perfiles de usuario ──────────────────────────────────────────────────
    // Solo el propio usuario puede escribir su perfil.
    // Cualquier usuario autenticado puede leer (para mostrar nombres en grupos).
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Grupos ───────────────────────────────────────────────────────────────
    match /groups/{groupId} {

      // Cualquier usuario autenticado puede leer grupos
      // (necesario para buscar por inviteCode al unirse).
      allow read: if request.auth != null;

      // Solo usuarios autenticados pueden crear un grupo,
      // y deben ser el creador y el primer miembro.
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid
                    && request.auth.uid in request.resource.data.memberIds;

      // Un miembro puede actualizar el grupo (ej: picks, settings futuros).
      // Un usuario no-miembro también puede actualizarlo SOLO para agregarse
      // a sí mismo en memberIds (flujo de unirse con inviteCode).
      allow update: if request.auth != null
                    && (
                      request.auth.uid in resource.data.memberIds
                      || request.auth.uid in request.resource.data.memberIds
                    );

      // Solo el creador puede eliminar el grupo.
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.createdBy;

      // ── Subcolecciones de semanas y picks (PR-5 y PR-6) ──────────────────
      match /weeks/{weekId} {
        allow read:  if request.auth != null
                     && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
        allow write: if request.auth != null
                     && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        match /picks/{userId} {
          allow read:  if request.auth != null
                       && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
          allow write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // ── Standings (PR-7) ─────────────────────────────────────────────────────
    match /standings/{groupId}/members/{userId} {
      allow read: if request.auth != null
                  && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
      // Escritura solo desde Cloud Functions (PR-6) — no desde el cliente.
      allow write: if false;
    }
  }
}
